# ============================================================
#  Adult Media Manager — User Configuration
#  Copy this file to .env and edit it.
#  Then run: docker compose up -d
# ============================================================

# ----- PORT ------------------------------------------------
# The port the web UI will be available on.
# Change this to any free port on your host.
AMM_PORT=8887

# ----- PERMISSIONS -----------------------------------------
# Match these to your host user.
# Run: id -u   (for PUID)
#      id -g   (for PGID)
PUID=1000
PGID=1000

# ----- MATCHING --------------------------------------------
# Date matching tolerance, in days. A scene's filename date must fall within
# this many days of the API release date to contribute to the match score.
# Default 7 (steep curve: exact=strong, ±2d=normal drift, ±7d=weak).
# Raise it (e.g. 30) if your filenames carry unreliable/approximate dates.
# AMM_DATE_TOLERANCE_DAYS=7

# ----- NEAR-DUPLICATE DETECTION ----------------------------
# Set to 1 to compute a perceptual hash (pHash) for each scanned video. This
# lets the Duplicates view group *re-encodes* of the same scene (different
# resolution/bitrate/container) — not just byte-identical copies. It decodes one
# frame per file with ffmpeg, so it makes scanning noticeably slower; leave it
# off (0) unless you want near-duplicate grouping. Off by default.
# AMM_SCAN_PHASH=0

# ----- POSTER ARTWORK --------------------------------------
# When renaming an API-matched scene, download its poster image and save it next
# to the video as "<name>-poster.jpg" (referenced by the .nfo) so Jellyfin/Plex
# show it. On by default. Set to 0 for zero-egress deployments where the server
# itself should make no outbound image requests. (Posters chosen manually in the
# Edit dialog are copied locally and are never affected by this setting.)
# AMM_FETCH_POSTERS=1

# ----- BROWSING / MOUNTS -----------------------------------
# The in-app Browse picker shows the built-in roots that exist:
#   /media /mnt /data /downloads /organized /home /srv /nas /storage /run/media
# Mount your media under one of those and it appears automatically. If you mount
# somewhere else, list it here (colon-separated) so Browse and Scan allow it.
# AMM_EXTRA_ROOTS=/library:/tank

# ----- TPDB API KEY ----------------------------------------
# Optional here — if left blank, add your key via the ⚙ Settings page in the UI.
# Keys set here always take priority over the Settings page.
#
# How to get your key:
#   1. Create a free account at https://theporndb.net/
#   2. Click your username (top-right) → API Keys
#   3. Copy the key and paste it below
TPDB_API_KEY=

# ----- STASHDB API KEY (optional, completely free) ---------
# Optional here — can also be added via the ⚙ Settings page in the UI.
#
# How to get your key:
#   1. Register at https://stashdb.org/register
#      Use invite code: 3bf7c4b8-b7a6-45b8-a8a6-8b38c10b8fa6
#   2. After login, click your username (top-right) → copy the API Key
#      It starts with: eyJ...
STASHDB_API_KEY=
